{
  "name": "astrelio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Frontend-only astrology app: natal, transits, progressions, solar return, synastry. Vue 3 + Pug + Pinia + astronomy-engine.",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
